{
  "name": "@msm-core/nemo",
  "version": "2.1.0",
  "description": "Evolving semantic memory and intent router — CST tokenizer + HDC algebra",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msm-core/nemo.git"
  },
  "keywords": [
    "hdc",
    "hypervector",
    "semantic",
    "memory",
    "router",
    "agent",
    "nlp",
    "intent"
  ],
  "author": "Emad",
  "license": "MIT",
  "scripts": {
    "build": "tsc && node scripts/fix-esm.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "ARCHITECTURE.md",
    "AGENTS.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.22.3",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@msm-core/cst": "^0.3.0"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true,
          "diagnostics": false,
          "tsconfig": {
            "module": "ESNext",
            "moduleResolution": "bundler"
          }
        }
      ]
    }
  }
}